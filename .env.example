# Αντίγραψέ το σε .env.local και συμπλήρωσε τις τιμές.
# Το .env.local ΔΕΝ μπαίνει ποτέ στο git.

# Neon connection string (Dashboard → Project → Connection Details → Pooled connection)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Μυστικό για την υπογραφή του session cookie. Τουλάχιστον 32 χαρακτήρες.
# Φτιάξε ένα με: openssl rand -base64 32
# Τοπικό και production είναι ανεξάρτητα — δεν χρειάζεται να ταιριάζουν.
SESSION_SECRET=""

# Resend API key, για την επαναφορά κωδικού (resend.com -> API Keys).
# Χωρίς αυτό, ο σύνδεσμος «Ξέχασα τον κωδικό» απλώς δεν εμφανίζεται.
RESEND_API_KEY=""

# Προαιρετικά. Μόνο αν έχεις επαληθεύσει domain στο Resend· αλλιώς
# χρησιμοποιείται το onboarding@resend.dev, που στέλνει μόνο στο email
# που κατέχει τον λογαριασμό Resend.
# EMAIL_FROM="Κοινό Ταμείο <tameio@to-domain-sou.gr>"

# Προαιρετικά. Η βάση για τους συνδέσμους επαναφοράς. Default: το production URL.
# APP_URL="https://tameio2-app.vercel.app"
